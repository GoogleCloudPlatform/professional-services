# --- Gemini Computer Use: Docker Configuration ---

# 1. Google Cloud Configuration
# Run 'gcloud config get-value project' to find your project ID
GCP_PROJECT_ID="your-project-id"
GCP_REGION="us-central1"

# 2. Permissions & Identity
# Run 'id -u' and 'id -g' on Linux to get these values
UID=1000
GID=1000

# 3. Execution Toggles
# Set to 'true' if you need the agent to "see" native OS elements (e.g., <select>)
USE_XVFB=false
# Set to 'false' if you want the agent to use the virtual display
PLAYWRIGHT_HEADLESS=true

# 4. Timezone
TZ=America/Los_Angeles
