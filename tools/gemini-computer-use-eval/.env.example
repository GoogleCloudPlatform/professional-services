# --- Google Cloud Project Config ---
GCP_PROJECT_ID="your-project-id"
GCP_REGION="global"

# --- Model Selection ---
# The agent model (must support Computer Use)
GCP_MODEL_NAME="gemini-3-flash-preview"
# The judge model for Video/Log analysis
GCP_JUDGE_MODEL="gemini-3.1-pro-preview"

# --- Browser Configuration ---
# Set to 'false' to see the browser window for debugging
GCP_HEADLESS_MODE=true

# --- Safety & Interaction ---
# Policy: 'auto' (default), 'interactive', 'auto-approve', 'auto-deny'
GCP_SAFETY_MODE="auto"

# --- Authentication ---
# Option A: ADC (Recommended) - Leave empty and run 'gcloud auth application-default login'
# Option B: API Key (For prototyping)
GCP_API_KEY=""

# --- Video Judge (Required for Vertex AI / Cloud Mode) ---
# Staging bucket for recorded videos (e.g., "my-eval-videos")
GCP_GCS_BUCKET=""

# --- BigQuery Export (Optional) ---
GCP_ENABLE_BIGQUERY=false
GCP_BIGQUERY_DATASET="computer_use_evals"
GCP_BIGQUERY_TABLE="runs"

# --- Vertex AI GenAI Evaluation Service (Autorater) ---
GCP_USE_VERTEX_EVAL=false

# --- Vertex AI Sandbox (Optional / Private Preview) ---
GCP_USE_SANDBOX=false
# GCP_SANDBOX_SERVICE_ACCOUNT="sa@project.iam.gserviceaccount.com"
# GCP_VERTEX_API_BASE_URL="https://us-central1-aiplatform.googleapis.com/"
