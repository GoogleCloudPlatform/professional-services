# Frontend configuration
# Use '/api' to utilize the Vite dev proxy (recommended for local dev)
# or the full URL 'http://localhost:8080/api' if bypassing the proxy.
VITE_API_BASE_URL=/api

# Backend configuration
PORT=8080
USE_VERTEX_AI=false # Set to true to use Vertex AI Live API instead of Developer API
GEMINI_LIVE_API_KEY=your_gemini_key_here


# HeyGen Avatar Configuration
HEYGEN_API_KEY=your_heygen_key_here
HEYGEN_AVATAR_ID=073b60a9-89a8-45aa-8902-c358f64d2852

# Vertex AI Search configuration
VERTEX_PROJECT_ID=your_gcp_project_id
VERTEX_LOCATION=global
VERTEX_DATA_STORE_ID="your-data-store-id-here"
VERTEX_ENGINE_ID="your-search-engine-id-here"
# Regional location scope for Vertex Search queries (optional, defaults to VERTEX_LOCATION)
VERTEX_SEARCH_LOCATION=global

# Whitelisted 1P Avatar preset name (case-sensitive)
# Options: Kira, Ingrid, Vera, Jay, Paul, Sam, Piper, Carmen, Kai, Leo, Ben
# Aligns with backend code fallback ("Vera")
GOOGLE_1P_AVATAR_NAME=Vera

# Gemini Live Model Configuration
# Use 'gemini-3.1-flash-live-preview' for the Developer API
GOOGLE_AI_MODEL=gemini-3.1-flash-live-preview
# Model used for Vertex AI (Standard Audio sessions)
VERTEX_AI_MODEL=publishers/google/models/gemini-live-2.5-flash-native-audio

# Voice Activity Detection (VAD)
# Duration of silence (in milliseconds) before the server marks the end of a user's turn
# Default for demo environments is 600ms.
VAD_SILENCE_DURATION_MS=600

# Path to built frontend files (used by backend to serve static content)
STATIC_DIR=../frontend/dist

# Vertex AI Custom Avatar Model (Requires Whitelist)
VERTEX_AI_AVATAR_MODEL=publishers/google/models/gemini-3.1-flash-live-preview-04-2026

# Scenario Storage In-Memory Cache TTL (optional, defaults to 5)
SCENARIO_CACHE_TTL_MINUTES=5
