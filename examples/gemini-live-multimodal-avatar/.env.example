# Frontend configuration
VITE_API_BASE_URL=/api

# Backend Server configuration
PORT=8080
STATIC_DIR=../frontend/dist
COMPANY_NAME="Cymbal Bank"

# Gemini Live Modality & Model Configuration
AVATAR_MODE=none
USE_VERTEX_AI=false
GOOGLE_AI_MODEL=gemini-3.1-flash-live-preview
VERTEX_AI_MODEL=publishers/google/models/gemini-live-2.5-flash-native-audio
VERTEX_AI_AVATAR_MODEL=publishers/google/models/gemini-3.1-flash-live-preview-04-2026

# Voice Activity Detection (VAD)
# Duration of silence (in milliseconds) before the server marks the end of a user's turn
VAD_SILENCE_DURATION_MS=600

# Cache TTL Configuration
SCENARIO_CACHE_TTL_MINUTES=5

# Vertex AI Search (Discovery Engine) Configuration
VERTEX_PROJECT_ID=your_gcp_project_id
VERTEX_LOCATION=global
VERTEX_SEARCH_LOCATION=global
VERTEX_DATA_STORE_ID="your-data-store-id-here"
VERTEX_ENGINE_ID="your-search-engine-id-here"

# HeyGen Service Configuration
HEYGEN_API_KEY=your_heygen_key_here
HEYGEN_AVATAR_ID=073b60a9-89a8-45aa-8902-c358f64d2852

# Developer API (AI Studio) Keys
GEMINI_LIVE_API_KEY=your_gemini_key_here

# Firebase Frontend Configuration (Optional - only required if OAuth/authentication is re-enabled)
# To re-enable authentication, set BYPASS_AUTH = false in frontend/src/context/AuthContext.tsx 
# and bypassAuth = false in backend/internal/handler/auth_middleware.go
# VITE_FIREBASE_API_KEY=your_firebase_api_key
# VITE_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain
# VITE_FIREBASE_PROJECT_ID=your_firebase_project_id
# VITE_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket
# VITE_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id
# VITE_FIREBASE_APP_ID=your_firebase_app_id
